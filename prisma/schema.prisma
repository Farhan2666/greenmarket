generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  role          Role      @default(BUYER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  products      Product[]
  orders        Order[]
  cartItems     CartItem[]
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

model Product {
  id            String     @id @default(cuid())
  name          String
  description   String
  price         Int
  images        String[]
  category      String
  stock         Int        @default(0)
  rating        Float      @default(0)
  sellerId      String
  seller        User       @relation(fields: [sellerId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  orderItems    OrderItem[]
  cartItems     CartItem[]
}

model Order {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id])
  status          OrderStatus @default(WAITING_PAYMENT)
  total           Int
  paymentMethod   String     @default("")
  shippingAddress Json       @default("{}")
  paymentProof    String     @default("")
  paidAt          DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  items           OrderItem[]
}

enum OrderStatus {
  WAITING_PAYMENT
  PAID
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Int
}

model CartItem {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
}
